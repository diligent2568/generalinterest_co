---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteData } from "../data/siteData";
import DarkVeil from "../components/DarkVeil";

const team = siteData.teamShowcase;
---

<BaseLayout title="Page 1 — Business Acquisition Consulting" logoOverride="/images/GENERAL_INTEREST_TEST_01.svg" logoOverrideWhite="/images/GENERAL_INTEREST_TEST_01_white.svg" footerLogoOverride="/images/GENERAL_INTEREST_TEST_01_white.svg">
  <!-- Hero -->
  <!-- Gradual blur overlay (bottom of viewport) -->
  <div class="gradual-blur gradual-blur-fixed">
    <div class="gradual-blur-inner">
      <div style="position:absolute;inset:0;top:auto;height:60%;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);mask-image:linear-gradient(to top,rgba(0,0,0,1),rgba(0,0,0,0));-webkit-mask-image:linear-gradient(to top,rgba(0,0,0,1),rgba(0,0,0,0));"></div>
      <div style="position:absolute;inset:0;top:auto;height:40%;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);mask-image:linear-gradient(to top,rgba(0,0,0,1),rgba(0,0,0,0));-webkit-mask-image:linear-gradient(to top,rgba(0,0,0,1),rgba(0,0,0,0));"></div>
    </div>
  </div>
  <section class="p1-hero">
    <div class="p1-hero__bg">
      <DarkVeil client:only="react" hueShift={203} noiseIntensity={0.07} scanlineIntensity={0.48} speed={1.1} scanlineFrequency={2.8} warpAmount={0.9} />
    </div>
    <div class="container p1-hero__inner">
      <span class="p1-tag" data-anim>Business Acquisition &amp; Advisory</span>
      <h1 class="p1-hero__title" data-anim>Navigating Business<br />Transitions With Confidence</h1>
      <p class="p1-hero__desc" data-anim>Expert guidance through acquisitions, due-diligence evaluations, and ownership transfers — so you can move forward with clarity.</p>
      <a href="/contact/" class="p1-btn p1-btn--primary" data-anim>Free Consultation</a>
    </div>
    <div class="p1-hero__stats">
      <div class="container p1-hero__stats-row">
        <div class="p1-stat" data-anim><span class="p1-stat__num">120+</span><span class="p1-stat__label">Deals Closed</span></div>
        <div class="p1-stat" data-anim><span class="p1-stat__num">$2.4B</span><span class="p1-stat__label">Transaction Value</span></div>
        <div class="p1-stat" data-anim><span class="p1-stat__num">98%</span><span class="p1-stat__label">Client Retention</span></div>
      </div>
    </div>
  </section>

  <!-- Intro / Brand -->
  <section class="p1-section p1-intro">
    <div class="container p1-intro__grid">
      <div class="p1-intro__image" data-anim>
        <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=80" alt="Infrastructure construction site" loading="lazy" />
      </div>
      <div class="p1-intro__content">
        <span class="p1-tag" data-anim>Who We Are</span>
        <h2 class="p1-section__title" data-anim>Build Value.<br />Unlock Potential.</h2>
        <p data-anim>At General Interest, we guide business owners through the most critical transitions — from acquisition and due-diligence to full ownership transfer. Our team brings decades of combined expertise in infrastructure, construction, and technology consulting.</p>
        <blockquote class="p1-quote" data-anim>
          <p>"Our goal is to equip you with the essential resources and guidance to transform your business vision into reality."</p>
          <cite>— General Interest Advisory Team</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Operations / Expertise -->
  <section class="p1-section p1-section--alt p1-ops">
    <div class="container">
      <div class="p1-ops__header">
        <span class="p1-tag" data-anim>Our Expertise</span>
        <h2 class="p1-section__title" data-anim>Comprehensive Support For Every Phase Of Business Transition</h2>
      </div>
      <div class="p1-ops__grid">
        <div class="p1-ops__text">
          <div class="p1-check-item" data-anim>
            <span class="p1-check">✓</span>
            <div>
              <h4>End-To-End Due Diligence</h4>
              <p>Thorough financial, operational, and legal evaluation of target businesses to mitigate risk and reveal true value.</p>
            </div>
          </div>
          <div class="p1-check-item" data-anim>
            <span class="p1-check">✓</span>
            <div>
              <h4>Seamless Ownership Transfers</h4>
              <p>Structured transition planning that protects continuity, preserves culture, and maximizes deal value for both parties.</p>
            </div>
          </div>
        </div>
        <div class="p1-ops__image" data-anim>
          <img src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=800&q=80" alt="Engineering and construction project" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Marquee -->
  <div class="p1-marquee">
    <div class="p1-marquee__track">
      <span>Acquisition</span><span>•</span>
      <span>Due Diligence</span><span>•</span>
      <span>Ownership Transfer</span><span>•</span>
      <span>Consulting</span><span>•</span>
      <span>Acquisition</span><span>•</span>
      <span>Due Diligence</span><span>•</span>
      <span>Ownership Transfer</span><span>•</span>
      <span>Consulting</span><span>•</span>
      <span>Acquisition</span><span>•</span>
      <span>Due Diligence</span><span>•</span>
      <span>Ownership Transfer</span><span>•</span>
      <span>Consulting</span><span>•</span>
    </div>
  </div>

  <!-- Services -->
  <section class="p1-section p1-services">
    <div class="container">
      <span class="p1-tag" data-anim>Services</span>
      <h2 class="p1-section__title" data-anim>Empowering Businesses Through Critical Transitions</h2>
      <div class="p1-services__grid">
        <div class="p1-service-card" data-anim>
          <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=600&q=80" alt="Commercial building development" loading="lazy" />
          <div class="p1-service-card__body">
            <h3>Business Acquisition Consulting</h3>
            <p>Strategic advisory for identifying, evaluating, and acquiring mid-size businesses in infrastructure and construction.</p>
          </div>
        </div>
        <div class="p1-service-card" data-anim>
          <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&q=80" alt="Due diligence financial review" loading="lazy" />
          <div class="p1-service-card__body">
            <h3>Due-Diligence Evaluations</h3>
            <p>Comprehensive assessments covering financials, operations, compliance, and market position — leave nothing to chance.</p>
          </div>
        </div>
        <div class="p1-service-card" data-anim>
          <img src="https://images.unsplash.com/photo-1589939705384-5185137a7f0f?w=600&q=80" alt="Construction engineering technology" loading="lazy" />
          <div class="p1-service-card__body">
            <h3>Ownership Transfer Planning</h3>
            <p>End-to-end support for business sales and transfers, including valuation, negotiation, and post-close integration.</p>
          </div>
        </div>
        <div class="p1-service-card" data-anim>
          <img src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?w=600&q=80" alt="Design and engineering technology" loading="lazy" />
          <div class="p1-service-card__body">
            <h3>Market Research &amp; Analysis</h3>
            <p>Data-driven insights into industry trends, competitive landscapes, and growth opportunities in your target sector.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="p1-section p1-section--alt p1-process">
    <div class="container">
      <span class="p1-tag" data-anim>How We Work</span>
      <h2 class="p1-section__title" data-anim>Consulting For Enhanced Clarity And Confidence</h2>
      <div class="p1-process__grid">
        <a class="p1-process__card" href="/contact/" data-anim>
          <img src="https://images.unsplash.com/photo-1560520653-9e0e4c89eb11?w=600&q=80" alt="Strategic planning meeting" loading="lazy" />
          <div class="p1-process__info">
            <span class="p1-process__num">01</span>
            <h4>Strategic Planning &amp; Discovery</h4>
            <p>We start by understanding your goals, market position, and ideal acquisition or exit profile.</p>
          </div>
        </a>
        <a class="p1-process__card" href="/contact/" data-anim>
          <img src="https://images.unsplash.com/photo-1507679799987-c73779587ccf?w=600&q=80" alt="Business evaluation" loading="lazy" />
          <div class="p1-process__info">
            <span class="p1-process__num">02</span>
            <h4>Evaluation &amp; Due Diligence</h4>
            <p>Our team conducts rigorous financial and operational analysis to validate value and identify risks.</p>
          </div>
        </a>
        <a class="p1-process__card" href="/contact/" data-anim>
          <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80" alt="Deal negotiation" loading="lazy" />
          <div class="p1-process__info">
            <span class="p1-process__num">03</span>
            <h4>Negotiation &amp; Close</h4>
            <p>We support deal structuring, negotiation, and smooth handoff to ensure a successful outcome for all parties.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- About / Personal -->
  <section class="p1-section p1-about">
    <div class="container p1-about__grid">
      <div class="p1-about__content">
        <span class="p1-tag" data-anim>Why General Interest</span>
        <h2 class="p1-section__title" data-anim>For Others, It's Just Business.<br />For Us, It's Personal.</h2>
        <p data-anim>We specialize in mid-size development companies across infrastructure, construction, design, and engineering technology. Our approach is hands-on, our relationships are long-term, and our commitment is to your success — not just the transaction.</p>
        <div class="p1-about__cols">
          <div data-anim>
            <h4>Infrastructure &amp; Construction</h4>
            <p>Deep operational knowledge of the firms that build and maintain critical infrastructure across the country.</p>
          </div>
          <div data-anim>
            <h4>Design &amp; Engineering Tech</h4>
            <p>Understanding of the technology landscape that powers modern design, engineering, and project delivery.</p>
          </div>
        </div>
      </div>
      <div class="p1-about__images">
        <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=600&q=80" alt="Infrastructure bridge" loading="lazy" class="p1-about__img p1-about__img--top" data-anim />
        <img src="https://images.unsplash.com/photo-1581092335397-9583eb92d232?w=600&q=80" alt="Construction workers on site" loading="lazy" class="p1-about__img p1-about__img--bottom" data-anim />
      </div>
    </div>
  </section>

  <!-- Our Team -->
  <section class="p1-section p1-section--dark p1-team">
    <div class="container">
      <div class="p1-team__header">
        <span class="p1-tag" data-anim>{team.title}</span>
        <h2 class="p1-section__title" data-anim>{team.subtitle}</h2>
      </div>
      <div class="p1-team__grid">
        {team.members.map((member) => (
          <div class="p1-team-card" data-anim>
            <img src={member.image} alt={member.name} loading="lazy" class="p1-team-card__image" />
            <h3 class="p1-team-card__name">{member.name}</h3>
            <span class="p1-team-card__role">{member.role}</span>
            <p class="p1-team-card__bio">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="p1-section p1-cta">
    <div class="container p1-cta__inner">
      <h2 class="p1-section__title" data-anim>Discover How Our Advisory Can Transform Your Next Deal</h2>
      <p data-anim>Whether you're acquiring, selling, or transitioning a business, our team is here to ensure you move forward with confidence and clarity.</p>
      <div class="p1-cta__btns" data-anim>
        <a href="/contact/" class="p1-btn p1-btn--primary">Free Consultation</a>
        <a href="/contact/" class="p1-btn p1-btn--outline">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Force header dark + white logo on Page 1 regardless of OS theme -->
<style is:global>
  .header {
    background-color: #1a1613 !important;
    border-bottom-color: rgba(255,255,255,0.08) !important;
  }
  /* Hide both default logo imgs and show our own */
  .header .logo--dark,
  .header .logo--light {
    display: none !important;
  }
  .header .header__logo::before {
    content: "";
    display: block;
    width: 160px;
    height: 40px;
    background: url("/images/GENERAL_INTEREST_TEST_01.svg") no-repeat center / contain;
    filter: brightness(0) invert(1);
  }
  .header .header__nav a {
    color: rgba(255,255,255,0.65) !important;
  }
  .header .header__nav a:hover,
  .header .header__nav a.active {
    color: #fff !important;
  }
  .header .header__menu-btn svg {
    stroke: #fff !important;
  }
  /* Footer logo - also white */
  .footer .logo--dark,
  .footer .logo--light {
    display: none !important;
  }
  .footer .footer__logo::before {
    content: "";
    display: block;
    width: 160px;
    height: 40px;
    background: url("/images/GENERAL_INTEREST_TEST_01.svg") no-repeat center / contain;
    filter: brightness(0) invert(1);
  }
</style>

<!-- Scroll-in animation script -->
<script>
  // Assign sequential stagger delays within each section
  document.querySelectorAll('.p1-hero, .p1-section, .p1-marquee, .p1-cta').forEach((section) => {
    const els = section.querySelectorAll('[data-anim]');
    els.forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 120}ms`;
    });
  });

  const animEls = document.querySelectorAll('[data-anim]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('anim--visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  animEls.forEach((el) => observer.observe(el));
</script>

<style>
  /* ================================
     PAGE 1 – Consultek-inspired
     Brown / Beige / Desaturated tones
     ================================ */

  /* Palette – Full dark mode */
  :root {
    --p1-brand: #b08f5a;
    --p1-brand-dark: #8a6f3e;
    --p1-bg-dark: #1a1613;
    --p1-bg-section: #241f1b;
    --p1-bg-light: #2e2722;
    --p1-bg-card: #332c26;
    --p1-text: rgba(255,255,255,0.85);
    --p1-text-muted: rgba(255,255,255,0.55);
    --p1-heading: #fff;
    --p1-white: #fff;
    --p1-border: rgba(255,255,255,0.1);
  }

  /* Utilities */
  .p1-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--p1-brand);
    margin-bottom: 16px;
  }

  .p1-section {
    padding: 100px 0;
    background-color: var(--p1-bg-light);
    color: var(--p1-text);
  }

  .p1-section--alt {
    background-color: var(--p1-bg-section);
  }

  .p1-section__title {
    font-size: 40px;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -1px;
    color: var(--p1-heading);
    margin-bottom: 24px;
  }

  .p1-btn {
    display: inline-block;
    padding: 16px 40px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    border: 2px solid transparent;
  }

  .p1-btn--primary {
    background-color: var(--p1-brand);
    color: var(--p1-white);
    border-color: var(--p1-brand);
  }
  .p1-btn--primary:hover {
    background-color: var(--p1-brand-dark);
    border-color: var(--p1-brand-dark);
    color: var(--p1-white);
  }

  .p1-btn--outline {
    background: transparent;
    color: var(--p1-white);
    border-color: rgba(255,255,255,0.25);
  }
  .p1-btn--outline:hover {
    border-color: var(--p1-brand);
    color: var(--p1-brand);
  }

  /* ---------- Hero ---------- */
  .p1-hero {
    position: relative;
    padding: 140px 0 0;
    background-color: var(--p1-bg-dark);
    color: var(--p1-white);
    overflow: hidden;
  }

  .p1-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .p1-hero__inner {
    position: relative;
    text-align: center;
    padding-bottom: 80px;
  }

  .p1-hero__title {
    font-size: 62px;
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -2px;
    margin-bottom: 24px;
    color: var(--p1-white);
  }

  .p1-hero__desc {
    font-size: 18px;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 40px;
    color: rgba(255,255,255,0.7);
  }

  .p1-hero__stats {
    background-color: var(--p1-brand);
  }

  .p1-hero__stats-row {
    display: flex;
    justify-content: center;
    gap: 60px;
    padding: 28px 0;
  }

  .p1-stat {
    text-align: center;
    color: var(--p1-white);
  }

  .p1-stat__num {
    display: block;
    font-size: 32px;
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1.2;
  }

  .p1-stat__label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    opacity: 0.85;
  }

  /* ---------- Intro ---------- */
  .p1-intro__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .p1-intro__image img {
    width: 100%;
    border-radius: 8px;
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  .p1-intro__content p {
    color: var(--p1-text-muted);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .p1-quote {
    border-left: 3px solid var(--p1-brand);
    padding-left: 20px;
    margin: 0;
  }

  .p1-quote p {
    font-style: italic;
    font-size: 16px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 8px;
  }

  .p1-quote cite {
    font-size: 13px;
    font-weight: 600;
    color: var(--p1-brand);
    font-style: normal;
  }

  /* ---------- Operations ---------- */
  .p1-ops__header {
    margin-bottom: 48px;
  }

  .p1-ops__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .p1-check-item {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
  }

  .p1-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--p1-brand);
    color: var(--p1-white);
    font-weight: 800;
    font-size: 16px;
    flex-shrink: 0;
  }

  .p1-check-item h4 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--p1-heading);
  }

  .p1-check-item p {
    font-size: 15px;
    color: var(--p1-text-muted);
    line-height: 1.7;
  }

  .p1-ops__image img {
    width: 100%;
    border-radius: 8px;
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  /* ---------- Marquee ---------- */
  .p1-marquee {
    background-color: #130f0d;
    padding: 20px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .p1-marquee__track {
    display: inline-flex;
    gap: 32px;
    animation: p1-scroll 20s linear infinite;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.5);
  }

  @keyframes p1-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ---------- Services ---------- */
  .p1-services__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    margin-top: 48px;
  }

  .p1-service-card {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--p1-border);
    background: var(--p1-bg-card);
    transition: box-shadow 0.3s;
  }

  .p1-service-card:hover {
    box-shadow: 0 12px 32px rgba(0,0,0,0.25);
  }

  .p1-service-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  .p1-service-card__body {
    padding: 28px;
  }

  .p1-service-card__body h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--p1-heading);
  }

  .p1-service-card__body p {
    font-size: 15px;
    color: var(--p1-text-muted);
    line-height: 1.7;
  }

  /* ---------- Process ---------- */
  .p1-process__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 48px;
  }

  .p1-process__card {
    border-radius: 8px;
    overflow: hidden;
    background: var(--p1-bg-card);
    border: 1px solid var(--p1-border);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.3s;
    display: flex;
    flex-direction: column;
  }

  .p1-process__card:hover {
    box-shadow: 0 12px 32px rgba(0,0,0,0.25);
    color: inherit;
  }

  .p1-process__card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .p1-process__info {
    padding: 24px;
  }

  .p1-process__num {
    font-size: 32px;
    font-weight: 900;
    color: var(--p1-brand);
    line-height: 1;
    margin-bottom: 12px;
    display: block;
  }

  .p1-process__info h4 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--p1-heading);
  }

  .p1-process__info p {
    font-size: 14px;
    color: var(--p1-text-muted);
    line-height: 1.7;
  }

  /* ---------- About ---------- */
  .p1-about__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
