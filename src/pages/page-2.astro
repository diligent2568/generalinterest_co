---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page 2 — General Interest LLC" logoOverride="/images/GENERAL_INTEREST_TEST_02.svg" logoOverrideWhite="/images/GENERAL_INTEREST_TEST_02.svg" footerLogoOverride="/images/GENERAL_INTEREST_TEST_02.svg">

  <!-- ===== Custom Nav Overlay ===== -->
  <nav class="p2-nav">
    <div class="container p2-nav__inner">
      <a href="#about" class="p2-nav__link">About</a>
      <a href="#services" class="p2-nav__link">Services</a>
      <a href="#team" class="p2-nav__link">Team</a>
      <a href="/contact/" class="p2-nav__link">Contact</a>
    </div>
  </nav>

  <!-- ===== 1. HERO ===== -->
  <section id="p2-hero-vanta" class="p2-hero" data-anim>
    <div class="container p2-hero__inner">
      <h1 class="p2-hero__title" data-anim>
        Engineering the<br />Future of Your<br />Legacy.
      </h1>
      <p class="p2-hero__sub" data-anim>We transform mid-market infrastructure and energy firms into high-valuation, autonomous assets. Combining architectural precision with broadcast-grade narrative, we build the systems that make your business undeniable.</p>
      <a href="/contact/" class="p2-btn" data-anim>Book a Valuation Strategy Session</a>
    </div>
    <div class="p2-hero__divider"></div>
  </section>

  <!-- ===== 2. MISSION ===== -->
  <section id="about" class="p2-section p2-mission">
    <div class="container p2-mission__grid">
      <div class="p2-mission__label" data-anim>
        <span class="p2-eyebrow">The General Interest Standard</span>
      </div>
      <div class="p2-mission__content">
        <h2 class="p2-heading" data-anim>From Operational Grit<br />to Enterprise Value.</h2>
        <p data-anim>Most $1M+ SDE businesses are built on years of hard-earned expertise, but they are often limited by their own success. We specialize in the Optimization-to-Exit pipeline.</p>
        <p data-anim>Whether you are scaling for a decade of growth or preparing for a high-multiple sale, General Interest LLC provides the structural rigor and digital automation required to decouple the owner from the operation — turning a "job" into a high-yield institutional asset.</p>
      </div>
    </div>
  </section>

  <!-- ===== 3. SERVICES — 3 Pillars ===== -->
  <section id="services" class="p2-section p2-section--dark p2-services">
    <div class="p2-services__bg"></div>
    <div class="container">
      <span class="p2-eyebrow p2-eyebrow--light" data-anim>Core Service Offerings</span>
      <h2 class="p2-heading p2-heading--light" data-anim>The Three Pillars</h2>

      <!-- Pillar 1 -->
      <div class="p2-pillar" data-anim>
        <div class="p2-pillar__num">I</div>
        <div class="p2-pillar__body">
          <h3 class="p2-pillar__title">Operational Integrity: Building the Business Machine</h3>
          <span class="p2-pillar__subtitle">Structural Optimization &amp; Blueprinting</span>
          <div class="p2-pillar__cols">
            <div>
              <h4>The Challenge</h4>
              <p>Your business relies on "Tribal Knowledge" and manual oversight, making it a liability to sophisticated buyers.</p>
            </div>
            <div>
              <h4>Our Solution</h4>
              <p>We conduct a top-down architectural audit of your workflows. We map every process and eliminate bottlenecks in project management to deliver a "Digital Twin" of your operations.</p>
            </div>
            <div>
              <h4>The Result</h4>
              <p>A business that functions with precision, ensuring the brand thrives independently of the founder.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="p2-pillar__divider"></div>

      <!-- Pillar 2 -->
      <div class="p2-pillar" data-anim>
        <div class="p2-pillar__num">II</div>
        <div class="p2-pillar__body">
          <h3 class="p2-pillar__title">The Autonomous Firm: 2026 Tech-Stack Integration</h3>
          <span class="p2-pillar__subtitle">AI-Integrated Infrastructure</span>
          <div class="p2-pillar__cols">
            <div>
              <h4>The Challenge</h4>
              <p>Stagnant margins and high overhead due to manual bidding, scheduling, and reporting.</p>
            </div>
            <div>
              <h4>Our Solution</h4>
              <p>We deploy custom AI agents tailored for the construction and energy sectors. From automated estimation to real-time predictive site analytics, we move your firm from "reactive" to "predictive."</p>
            </div>
            <div>
              <h4>The Result</h4>
              <p>Radical efficiency that directly inflates your SDE and attracts tech-forward acquirers.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="p2-pillar__divider"></div>

      <!-- Pillar 3 -->
      <div class="p2-pillar" data-anim>
        <div class="p2-pillar__num">III</div>
        <div class="p2-pillar__body">
          <h3 class="p2-pillar__title">Prestige Positioning: From Vendor to Institution</h3>
          <span class="p2-pillar__subtitle">Market Authority &amp; Narrative Strategy</span>
          <div class="p2-pillar__cols">
            <div>
              <h4>The Challenge</h4>
              <p>You are the best in your field, but your digital presence lacks the "gravity" of a market leader.</p>
            </div>
            <div>
              <h4>Our Solution</h4>
              <p>Leveraging broadcast media expertise, we document your infrastructure legacy. We create high-fidelity content and 3D visualizations that position your firm as the gold standard.</p>
            </div>
            <div>
              <h4>The Result</h4>
              <p>A brand that commands a premium multiple and an aggressive buyer pool.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 4. TEAM ===== -->
  <section id="team" class="p2-section p2-team">
    <div class="container">
      <span class="p2-eyebrow" data-anim>Architects of Value</span>
      <h2 class="p2-heading" data-anim>The Team</h2>
      <p class="p2-team__intro" data-anim>A collective of specialists who have built at scale — from global coworking infrastructures to national broadcast networks.</p>

      <div class="p2-team__grid">
        <div class="p2-team-card" data-anim>
          <img src="/images/aaron.jpg" alt="Aaron David Mendonca" loading="lazy" class="p2-team-card__img" />
          <div class="p2-team-card__info">
            <h3>Aaron David Mendonca</h3>
            <span class="p2-team-card__role">Innovation &amp; Corporate Development</span>
            <p>Aaron bridges the gap between physical assets and corporate growth. With a background in architecture and energy, he previously served as the Head of Business Development at WeWork Construction Innovation. He specializes in identifying undervalued operational levers and engineering the strategic partnerships that drive high-multiple exits.</p>
          </div>
        </div>

        <div class="p2-team-card" data-anim>
          <img src="/images/beto.jpg" alt="Adalberto Avila" loading="lazy" class="p2-team-card__img" />
          <div class="p2-team-card__info">
            <h3>Adalberto Avila</h3>
            <span class="p2-team-card__role">Design &amp; Media Strategy</span>
            <p>A veteran of the high-stakes world of broadcast media, Adalberto is a Seasoned Motion Graphics Designer at NBCUniversal Telemundo. He translates complex industrial operations into compelling visual narratives. By leveraging 3D animation and creative strategy, he ensures our clients' businesses are positioned as institutional leaders.</p>
          </div>
        </div>

        <div class="p2-team-card" data-anim>
          <img src="/images/tim.jpg" alt="Tim Dumatrait" loading="lazy" class="p2-team-card__img" />
          <div class="p2-team-card__info">
            <h3>Tim Dumatrait</h3>
            <span class="p2-team-card__role">Technology &amp; Construction Systems</span>
            <p>Tim is a systems thinker with 15 years of experience at the intersection of creative design and technical execution. His expertise lies in driving technology solutions across product development and construction. He focuses on the "Internal Infrastructure," implementing the AI-driven automations that turn manual labor into scalable systems.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 5. LAKE COMO ===== -->
  <section class="p2-section p2-section--accent p2-como">
    <div class="container p2-como__grid">
      <div class="p2-como__content">
        <span class="p2-eyebrow p2-eyebrow--light" data-anim>The Residency</span>
        <h2 class="p2-heading p2-heading--light" data-anim>A Global Perspective<br />on Growth.</h2>
        <p data-anim>To maintain the high-touch nature of our consultancy, General Interest LLC only accepts a select number of partnerships per quarter. For our premier partners, we host strategic sessions at our private villa in Lake Como, Italy.</p>
        <p data-anim>This is where we finalize exit strategies and legacy planning in an environment built for high-level thinking, away from the noise of the day-to-day operation.</p>
      </div>
      <div class="p2-como__image" data-anim>
        <img src="/images/LakeComoVilla02.png" alt="Lake Como Villa, Italy" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ===== 6. FOOTER CTA ===== -->
  <section id="p2-cta-vanta" class="p2-section p2-section--dark p2-cta">
    <div class="container p2-cta__inner">
      <h2 class="p2-heading p2-heading--light p2-cta__title" data-anim>Your Business is an<br />Infrastructure Project.<br />Build it to Last.</h2>
      <div class="p2-cta__meta" data-anim>
        <p class="p2-cta__company">General Interest LLC</p>
        <p class="p2-cta__locations">Miami &nbsp;|&nbsp; New York &nbsp;|&nbsp; Lake Como, IT</p>
      </div>
      <a href="/contact/" class="p2-btn p2-btn--light" data-anim>Apply for a High-Impact Consultation</a>
      <p class="p2-cta__note" data-anim>Inquiries are limited to businesses with $1M+ SDE looking to institutionalize their legacy.</p>
    </div>
  </section>

</BaseLayout>

<!-- Force header dark + white logo -->
