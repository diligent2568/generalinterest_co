<!-- Vanta.js Waves Background -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.waves.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    if (window.VANTA) {
      var vantaSettings = {
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200,
        minWidth: 200,
        scale: 1.00,
        scaleMobile: 1.00,
        color: 0x191b18,
        waveHeight: 19.50,
        waveSpeed: 1,
        zoom: 0.9992042677475115,
        shininess: 30
      };
      window.VANTA.WAVES(Object.assign({}, vantaSettings, { el: '#p2-hero-vanta' }));
      window.VANTA.WAVES(Object.assign({}, vantaSettings, { el: '#p2-cta-vanta' }));
    }
  });
</script>

<!-- Scroll-in animation -->
<script>
  document.querySelectorAll('.p2-hero, .p2-section, .p2-cta').forEach((section) => {
    const els = section.querySelectorAll('[data-anim]');
    els.forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 100}ms`;
    });
  });

  const animEls = document.querySelectorAll('[data-anim]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('anim--visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  animEls.forEach((el) => observer.observe(el));

  // Parallax for wireframe background
  const servicesBg = document.querySelector('.p2-services__bg') as HTMLElement | null;
  if (servicesBg) {
    const section = servicesBg.parentElement!;
    const onScroll = () => {
      const rect = section.getBoundingClientRect();
      const viewH = window.innerHeight;
      if (rect.bottom > 0 && rect.top < viewH) {
        const progress = (viewH - rect.top) / (viewH + rect.height);
        const offset = (progress - 0.5) * 600;
        servicesBg.style.transform = `translateY(${offset}px)`;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>

<style>
  /* ================================
     PAGE 2 – Oak-inspired
     Dark editorial / serif headings
     ================================ */

  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;700&display=swap');

  :root {
    --p2-dark: #242424;
    --p2-dark-2: #393A36;
    --p2-dark-3: #2c2e27;
    --p2-dark-4: #2d2e28;
    --p2-accent: #242424;
    --p2-warm: #8a7a5a;
    --p2-light: #E1E1E0;
    --p2-white: #FFFFFF;
    --p2-border: rgba(225,255,224,0.2);
    --p2-text: rgba(255,255,255,0.7);
    --p2-text-dark: #242424;
    --p2-text-muted: rgba(36,36,36,0.6);
    --p2-serif: 'DM Serif Display', Georgia, serif;
    --p2-sans: 'DM Sans', 'Inter', sans-serif;
  }

  /* --- Utility --- */
  .p2-eyebrow {
    display: inline-block;
    font-family: var(--p2-sans);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--p2-warm);
    margin-bottom: 20px;
  }

  .p2-eyebrow--light {
    color: var(--p2-light);
    opacity: 0.6;
  }

  .p2-heading {
    font-family: var(--p2-serif);
    font-size: 48px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.5px;
    color: var(--p2-text-dark);
    margin-bottom: 28px;
  }

  .p2-heading--light {
    color: var(--p2-white);
  }

  .p2-btn {
    display: inline-block;
    font-family: var(--p2-sans);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 18px 40px;
    border: 1.5px solid var(--p2-dark);
    color: var(--p2-dark);
    text-decoration: none;
    transition: all 0.35s ease;
    background: transparent;
  }

  .p2-btn:hover {
    background: var(--p2-dark);
    color: var(--p2-white);
  }

  .p2-btn--light {
    border-color: var(--p2-light);
    color: var(--p2-light);
  }

  .p2-btn--light:hover {
    background: var(--p2-light);
    color: var(--p2-dark);
  }

  /* --- Sub-nav --- */
  .p2-nav {
    background: var(--p2-dark);
    border-bottom: 1px solid var(--p2-border);
  }

  .p2-nav__inner {
    display: flex;
    justify-content: center;
    gap: 48px;
    padding: 14px 0;
  }

  .p2-nav__link {
    font-family: var(--p2-sans);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.3s;
  }

  .p2-nav__link:hover {
    color: var(--p2-white);
  }

  /* --- Hero --- */
  .p2-hero {
    background: var(--p2-dark);
    color: var(--p2-white);
    padding: 120px 0 100px;
    position: relative;
    overflow: hidden;
  }

  .p2-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .p2-hero__divider {
    z-index: 1;
  }

  .p2-hero__title {
    font-family: var(--p2-serif);
    font-size: 80px;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -2px;
    color: var(--p2-white);
    margin-bottom: 36px;
  }

  .p2-hero__sub {
    font-family: var(--p2-sans);
    font-size: 17px;
    line-height: 1.8;
    color: rgba(255,255,255,0.55);
    max-width: 620px;
    margin-bottom: 48px;
  }

  .p2-hero .p2-btn {
    border-color: var(--p2-light);
    color: var(--p2-light);
  }

  .p2-hero .p2-btn:hover {
    background: var(--p2-light);
    color: var(--p2-dark);
  }

  .p2-hero__divider {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--p2-border);
  }

  /* --- Sections --- */
  .p2-section {
    padding: 100px 0;
    font-family: var(--p2-sans);
  }

  .p2-section p {
    font-size: 16px;
    line-height: 1.85;
    color: var(--p2-text-muted);
  }

  .p2-section--dark {
    background: var(--p2-dark);
  }

  /* --- Services wireframe bg --- */
  .p2-services {
    position: relative;
    overflow: hidden;
  }

  .p2-services > .container {
    position: relative;
    z-index: 1;
  }

  .p2-services__bg {
    position: absolute;
    inset: -120% -10%;
    background: url('/images/wireframe-blueprint.svg') center / cover no-repeat;
    opacity: 0.5;
    pointer-events: none;
    will-change: transform;
  }

  .p2-section--dark p {
    color: rgba(255,255,255,0.55);
  }

  .p2-section--accent {
    background: var(--p2-accent);
  }

  .p2-section--accent p {
    color: rgba(255,255,255,0.65);
  }

  /* --- Mission --- */
  .p2-mission {
    background: var(--p2-dark-3);
  }

  .p2-mission .p2-eyebrow {
    color: var(--p2-warm);
  }

  .p2-mission .p2-heading {
    color: var(--p2-white);
  }

  .p2-mission p {
    color: rgba(255,255,255,0.55);
  }

  .p2-mission__grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 80px;
    align-items: start;
  }

  .p2-mission__content p {
    margin-bottom: 20px;
  }

  /* --- Services / Pillars --- */
  .p2-pillar {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
    padding: 56px 0;
  }

  .p2-pillar__num {
    font-family: var(--p2-serif);
    font-size: 32px;
    color: rgba(255,255,255,0.2);
    padding-top: 4px;
  }

  .p2-pillar__title {
    font-family: var(--p2-serif);
    font-size: 30px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--p2-white);
    margin-bottom: 8px;
  }

  .p2-pillar__subtitle {
    display: inline-block;
    font-family: var(--p2-sans);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--p2-warm);
    margin-bottom: 28px;
  }

  .p2-pillar__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .p2-pillar__cols h4 {
    font-family: var(--p2-sans);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 12px;
  }

  .p2-pillar__cols p {
    font-size: 15px;
    line-height: 1.75;
  }

  .p2-pillar__divider {
    height: 1px;
    background: var(--p2-border);
  }

  /* --- Team --- */
  .p2-team {
    background: var(--p2-dark-4);
  }

  .p2-team .p2-eyebrow {
    color: var(--p2-warm);
  }

  .p2-team .p2-heading {
    color: var(--p2-white);
  }

  .p2-team .p2-section p,
  .p2-team p {
    color: rgba(255,255,255,0.55);
  }

  .p2-team__intro {
    max-width: 640px;
    margin-bottom: 60px;
    color: rgba(255,255,255,0.55);
  }

  .p2-team__grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .p2-team-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 48px;
    align-items: start;
    padding: 48px 0;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .p2-team-card:last-child {
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .p2-team-card__img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    filter: grayscale(0.3);
    transition: filter 0.4s;
  }

  .p2-team-card:hover .p2-team-card__img {
    filter: grayscale(0);
  }

  .p2-team-card__info h3 {
    font-family: var(--p2-serif);
    font-size: 26px;
    font-weight: 400;
    color: var(--p2-white);
    margin-bottom: 6px;
  }

  .p2-team-card__role {
    display: block;
    font-family: var(--p2-sans);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--p2-warm);
    margin-bottom: 20px;
  }

  .p2-team-card__info p {
    color: rgba(255,255,255,0.5) !important;
  }

  .p2-team-card__info p {
    font-size: 15px;
    line-height: 1.8;
    color: rgba(255,255,255,0.5);
    max-width: 580px;
  }

  /* --- Lake Como --- */
  .p2-como__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .p2-como__content p {
    margin-bottom: 16px;
  }

  .p2-como__image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  /* --- CTA Footer --- */
  .p2-cta {
    text-align: center;
    padding: 120px 0;
    background: var(--p2-dark);
    position: relative;
    overflow: hidden;
  }

  .p2-cta__inner {
    position: relative;
    z-index: 1;
  }

  .p2-cta__title {
